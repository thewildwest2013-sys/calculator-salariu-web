<!doctype html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Calculator salariu în ture</title>
  <meta name="theme-color" content="#0f172a" />
  <link rel="manifest" href="manifest.json" />
  <style>

html, body {
  margin: 0;
  padding: 0;
  width: 100%;
  min-height: 100%;
  background: #06152b;
}
body {
  padding-top: env(safe-area-inset-top, 0px);
  padding-bottom: env(safe-area-inset-bottom, 0px);
  box-sizing: border-box;
}
.wrap {
  box-sizing: border-box;
  min-height: 100vh;
  padding-top: calc(env(safe-area-inset-top, 0px) + 10px);
  padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 32px);
}
.topbar, .compact-topbar { 
  padding-top: 4px;
}
.main-layout,
.summary-hero,
.app-panel,
.days {
  box-sizing: border-box;
}
.wrap > *:last-child,
.main-layout > *:last-child,
.left-column > *:last-child,
.right-column > *:last-child {
  margin-bottom: calc(env(safe-area-inset-bottom, 0px) + 18px);
}
.days {
  padding-bottom: 8px;
}
@media (max-width: 640px) {
  .wrap {
    padding-top: calc(env(safe-area-inset-top, 0px) + 12px);
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 36px);
  }
  .compact-topbar {
    gap: 12px;
  }
}

:root{
  --bg:#07111f;--bg2:#0b1325;--card:#0f172a;--card2:#111c31;--soft:#17243d;--line:#26354f;
  --text:#e5eefc;--muted:#94a3b8;--accent:#22c55e;--cyan:#38bdf8;--violet:#8b5cf6;--amber:#f59e0b;
  --night:#60a5fa;--morning:#34d399;--after:#fbbf24;--weekend:#fb923c;--holiday:#fb7185;
}
*{box-sizing:border-box} html,body{height:100%}
body{margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:radial-gradient(circle at top left,#0f1e35 0%,#07111f 42%,#050b14 100%);color:var(--text);min-height:100vh;padding-top:calc(env(safe-area-inset-top,0px) + 68px)}
.wrap{max-width:1380px;margin:0 auto;padding:20px}.screen-shell{min-height:calc(100vh - (env(safe-area-inset-top,0px) + 68px));display:flex;align-items:center;justify-content:center;padding:24px}
h1,h2,h3,p{margin:0}.hidden{display:none}.muted{color:var(--muted)}
.card{background:linear-gradient(180deg,rgba(17,28,49,.96),rgba(12,20,36,.96));border:1px solid rgba(148,163,184,.12);border-radius:24px;padding:18px;box-shadow:0 16px 40px rgba(0,0,0,.28);backdrop-filter:blur(10px)}
.topbar{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:18px;flex-wrap:wrap}.brand{display:flex;align-items:center;gap:14px}.logo{position:relative;width:44px;height:44px;border-radius:15px;display:grid;place-items:center;color:transparent;font-size:0;overflow:hidden;background:radial-gradient(circle at 22% 18%,rgba(255,255,255,.28) 0 10%,transparent 11%),linear-gradient(145deg,#1d4ed8 0%,#0ea5e9 42%,#7c3aed 100%);box-shadow:0 14px 34px rgba(37,99,235,.34),0 0 0 1px rgba(255,255,255,.12) inset,0 0 22px rgba(59,130,246,.22);border:1px solid rgba(255,255,255,.16)}.logo::before{content:'';position:absolute;inset:8px 9px 10px 9px;border-radius:9px;background:linear-gradient(180deg,rgba(255,255,255,.16),rgba(255,255,255,.06));border:1px solid rgba(255,255,255,.22);box-shadow:inset 0 1px 0 rgba(255,255,255,.18)}.logo::after{content:'';position:absolute;left:13px;bottom:12px;width:18px;height:14px;border-radius:4px 4px 6px 6px;background:linear-gradient(180deg,#f8fafc,#dbeafe);box-shadow:8px -2px 0 -4px #22c55e,12px -5px 0 -4px #f59e0b,16px -8px 0 -4px #38bdf8}.brand h1{font-size:24px;line-height:1.1;letter-spacing:-.02em}.brand p{color:var(--muted);margin-top:4px}
.lang-switcher{position:fixed;top:calc(env(safe-area-inset-top,0px) + 10px);right:12px;z-index:1200;display:flex;gap:8px;padding:8px 10px;border-radius:999px;background:linear-gradient(180deg,rgba(7,17,34,.94),rgba(9,24,49,.88));border:1px solid rgba(148,163,184,.2);box-shadow:0 14px 32px rgba(0,0,0,.3),inset 0 1px 0 rgba(255,255,255,.04);backdrop-filter:blur(14px);pointer-events:auto}.lang-btn{position:relative;width:42px;height:42px;padding:0;border-radius:999px;display:grid;place-items:center;font-size:20px;background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.03));border:1px solid rgba(148,163,184,.16);box-shadow:inset 0 1px 0 rgba(255,255,255,.08);transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease,background .18s ease,filter .18s ease}.lang-btn:hover{transform:translateY(-1px) scale(1.02);border-color:rgba(191,219,254,.4);box-shadow:0 8px 20px rgba(15,23,42,.3),inset 0 1px 0 rgba(255,255,255,.1)}.lang-btn.active{background:linear-gradient(135deg,#1d4ed8 0%,#38bdf8 55%,#22c55e 100%);border-color:rgba(191,219,254,.95);box-shadow:0 12px 28px rgba(37,99,235,.46),0 0 0 4px rgba(59,130,246,.14),0 0 24px rgba(56,189,248,.28),inset 0 1px 0 rgba(255,255,255,.22);transform:translateY(-1px) scale(1.06);filter:saturate(1.08)}.lang-btn.active::after{content:'';position:absolute;bottom:-3px;left:50%;transform:translateX(-50%);width:16px;height:4px;border-radius:999px;background:linear-gradient(90deg,#f8fafc,#bfdbfe);box-shadow:0 0 10px rgba(191,219,254,.65)}.lang-btn span{filter:saturate(1.08);transform:translateY(-.5px)}
@keyframes activeLangPulse{0%,100%{box-shadow:0 12px 28px rgba(37,99,235,.46),0 0 0 4px rgba(59,130,246,.14),0 0 24px rgba(56,189,248,.28),inset 0 1px 0 rgba(255,255,255,.22)}50%{box-shadow:0 14px 32px rgba(37,99,235,.54),0 0 0 5px rgba(59,130,246,.18),0 0 28px rgba(34,197,94,.24),inset 0 1px 0 rgba(255,255,255,.22)}}
.lang-btn.active{animation:activeLangPulse 2.2s ease-in-out infinite}

@media (max-width:640px){body{padding-top:calc(env(safe-area-inset-top,0px) + 62px)}.screen-shell{min-height:calc(100vh - (env(safe-area-inset-top,0px) + 62px))}.logo{width:34px;height:34px;font-size:14px}.brand h1{font-size:21px}.lang-switcher{top:calc(env(safe-area-inset-top,0px) + 8px);right:10px;padding:6px 8px}.lang-btn{width:36px;height:36px;font-size:18px}}
.chip{padding:10px 14px;border-radius:999px;background:rgba(255,255,255,.06);border:1px solid rgba(148,163,184,.14);font-size:13px;color:var(--muted)}
.summary-hero{display:grid;grid-template-columns:1.25fr .8fr .8fr .9fr;gap:14px;margin-bottom:18px}.hero-card{padding:22px}.hero-card.primary{background:linear-gradient(135deg,#05111f,#071728 50%,#0a2031);border:1px solid rgba(56,189,248,.15)}
.hero-card .eyebrow{font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}.hero-card .big{font-size:56px;line-height:1;font-weight:800;margin-top:8px;color:#2ee6a6}.hero-card .unit{font-size:18px;color:var(--muted);margin-top:6px}.mini-stat .label{font-size:13px;color:var(--muted)} .mini-stat .value{font-size:34px;font-weight:800;margin-top:10px}
.grid{display:grid;gap:18px}.main-layout{grid-template-columns:minmax(0,1.55fr) minmax(320px,.85fr)}
.app-panel{padding:20px}.section-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;margin-bottom:14px}.section-head h2{font-size:28px}.section-head p{color:var(--muted);margin-top:4px}
.toolbar{display:flex;gap:10px;flex-wrap:wrap;align-items:center}.toolbar select,.toolbar button,.field input,.field select{font:inherit}
select,input{width:100%;padding:12px 14px;border-radius:16px;border:1px solid var(--line);background:#0a1528;color:var(--text)} select:focus,input:focus{outline:none;border-color:#3b82f6;box-shadow:0 0 0 4px rgba(59,130,246,.12)}
button{border:none;background:linear-gradient(135deg,#1d4ed8,#2563eb);color:#fff;padding:12px 16px;border-radius:16px;font:inherit;font-weight:600;cursor:pointer} button.secondary{background:#0a1528;color:var(--text);border:1px solid var(--line)} button.ghost{background:rgba(255,255,255,.06);color:var(--text);border:1px solid rgba(148,163,184,.14)}
.legend{display:flex;gap:10px;flex-wrap:wrap;margin:10px 0 16px}.pill{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;background:#0a1528;border:1px solid var(--line);font-size:13px;color:var(--muted)} .sw{width:12px;height:12px;border-radius:4px;display:inline-block}
.weekdays{display:none}.weekday{display:none}
.days{display:grid;grid-template-columns:repeat(7,1fr);gap:10px;max-height:none;overflow:visible;padding-right:0}.day{min-height:112px;border:1px solid rgba(96,165,250,.12);border-radius:20px;padding:12px;background:linear-gradient(180deg,rgba(30,41,59,.95),rgba(8,15,31,.98));display:flex;flex-direction:column;gap:8px;cursor:pointer;transition:transform .12s ease,border-color .2s, box-shadow .2s,background .2s}.day:hover{transform:translateY(-1px);border-color:#4f74b8;box-shadow:0 12px 30px rgba(2,6,23,.28)}.day.selected{border-color:#7dd3fc;box-shadow:0 0 0 3px rgba(56,189,248,.18),0 18px 40px rgba(2,6,23,.34);background:linear-gradient(180deg,rgba(15,23,42,.98),rgba(10,18,37,.98))}.day.weekend{background:linear-gradient(180deg,rgba(251,146,60,.28),rgba(88,39,8,.92));border-color:rgba(251,191,36,.3)}.day.holiday{background:linear-gradient(180deg,rgba(244,63,94,.30),rgba(92,14,38,.94));border-color:rgba(251,113,133,.34)}.day.today{border-color:rgba(96,165,250,.55);box-shadow:0 0 0 3px rgba(59,130,246,.14),0 18px 34px rgba(2,6,23,.26);background:linear-gradient(180deg,rgba(14,34,61,.98),rgba(9,19,38,.98))}
.day-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}.num{font-size:25px;font-weight:900;color:#f8fafc}.meta{font-size:11px;color:#94a3b8;text-transform:capitalize}.day-code{min-width:34px;height:34px;border-radius:12px;display:grid;place-items:center;font-weight:900;color:#08111d;box-shadow:inset 0 1px 0 rgba(255,255,255,.18),0 8px 18px rgba(15,23,42,.18)}.code-OFF{background:linear-gradient(135deg,#64748b,#475569);color:#e2e8f0}.code-M{background:linear-gradient(135deg,#34d399,#10b981)}.code-A{background:linear-gradient(135deg,#fbbf24,#f59e0b)}.code-N{background:linear-gradient(135deg,#60a5fa,#2563eb);color:#eff6ff}.code-CO{background:linear-gradient(135deg,#c4b5fd,#8b5cf6);color:#f5f3ff}.code-CM{background:linear-gradient(135deg,#fb7185,#e11d48);color:#fff1f2}
.tags{display:flex;gap:6px;flex-wrap:wrap}.tag{font-size:11px;padding:4px 8px;border-radius:999px;background:linear-gradient(135deg,rgba(59,130,246,.18),rgba(14,165,233,.18));border:1px solid rgba(125,211,252,.18);color:#dbeafe}.tag.weekend{background:linear-gradient(135deg,rgba(251,146,60,.30),rgba(251,191,36,.22));color:#fff7ed;border-color:rgba(251,146,60,.34);box-shadow:0 6px 14px rgba(251,146,60,.12)}.tag.holiday{background:linear-gradient(135deg,rgba(244,63,94,.30),rgba(251,113,133,.22));color:#fff1f2;border-color:rgba(251,113,133,.32);box-shadow:0 6px 14px rgba(244,63,94,.14)}.day-sub{margin-top:auto;font-size:12px;color:#dbeafe}.day.expanded{grid-column:span 2;min-height:330px}.inline-editor{margin-top:10px;padding-top:10px;border-top:1px solid rgba(148,163,184,.12)}.inline-editor-head{display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap}.inline-editor-title{font-size:12px;color:var(--text);font-weight:700}.inline-grid-two{display:grid;grid-template-columns:1fr 1fr;gap:8px}.tiny-shift-btn{padding:10px 8px;border-radius:14px;border:1px solid var(--line);background:#0b172c;color:var(--text);font-weight:700;text-align:center;cursor:pointer;font-size:12px}.tiny-shift-btn.active{border-color:#60a5fa;box-shadow:0 0 0 2px rgba(96,165,250,.12)}.tiny-shift-btn.code-OFF.active{background:#334155;color:#fff}.tiny-shift-btn.code-M.active{background:rgba(52,211,153,.22)}.tiny-shift-btn.code-A.active{background:rgba(251,191,36,.22)}.tiny-shift-btn.code-N.active{background:rgba(96,165,250,.22)}.tiny-field{display:flex;flex-direction:column;gap:6px;margin-top:8px}.tiny-field label{font-size:12px;color:var(--muted)}.tiny-field input{padding:10px 12px;border-radius:14px}.tiny-checks{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:8px}.tiny-check{display:flex;align-items:center;gap:8px;padding:10px;border:1px solid var(--line);border-radius:14px;background:#0b172c;font-size:12px}.tiny-check input{width:auto;margin:0}
.editor{margin-top:18px;padding:18px;border-radius:22px;background:linear-gradient(180deg,#0a1528,#0a1323);border:1px solid var(--line)}.editor-head{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;margin-bottom:14px}.editor-title{font-size:22px;font-weight:700}.row{display:grid;grid-template-columns:1fr 1fr;gap:12px}.field{display:flex;flex-direction:column;gap:6px}.field label{font-size:13px;color:var(--muted)}.mini-hint{font-size:12px;color:var(--muted);line-height:1.45;margin-top:8px}.check-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:10px}.check-chip{display:flex;align-items:center;gap:8px;padding:11px 12px;border:1px solid var(--line);border-radius:14px;background:#0b172c;font-size:13px;color:var(--text)}.check-chip input{width:auto;margin:0}.editor-block-title{font-size:13px;color:var(--muted);margin:14px 0 8px}.shift-picker{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:10px}.shift-btn{padding:12px 10px;border-radius:16px;border:1px solid var(--line);background:#0b172c;color:var(--text);font-weight:700;text-align:center;cursor:pointer;transition:transform .08s ease,border-color .2s,box-shadow .2s}.shift-btn:hover{transform:translateY(-1px)}.shift-btn.active{border-color:#60a5fa;box-shadow:0 0 0 3px rgba(96,165,250,.12)}.shift-btn.code-OFF.active{background:#334155;color:#fff}.shift-btn.code-M.active{background:rgba(52,211,153,.22)}.shift-btn.code-A.active{background:rgba(251,191,36,.22)}.shift-btn.code-N.active{background:rgba(96,165,250,.22)}.secondary-shifts{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:10px}.muted-note{font-size:12px;color:var(--muted);margin-top:2px}@media (max-width:700px){.shift-picker{grid-template-columns:repeat(2,1fr)}.secondary-shifts,.check-grid,.row,.tiny-checks,.inline-grid-two{grid-template-columns:1fr}}
.settings-card .stack{display:grid;gap:14px}.detail{display:grid;grid-template-columns:1fr;gap:18px}.list{display:flex;flex-direction:column;gap:10px}.item{display:flex;justify-content:space-between;gap:16px;border:1px solid var(--line);border-radius:16px;padding:12px 14px;font-size:14px;background:#0a1528}
.auth-wrap{max-width:560px;margin:40px auto;width:100%}.brand-chip{display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;background:rgba(79,70,229,.14);color:#c7d2fe;font-size:13px;font-weight:700;margin-bottom:14px}.tabs{display:flex;gap:8px;margin-bottom:12px}.tabs button{flex:1}.premium-benefits{display:grid;gap:10px;margin:16px 0}.premium-benefit,.auth-note{padding:12px 14px;border-radius:14px;background:#0a1528;border:1px solid var(--line);font-size:13px;color:var(--muted)}
.free-banner{margin:0 0 16px;padding:14px 16px;border:1px solid rgba(245,158,11,.25);background:rgba(245,158,11,.09);border-radius:18px;display:none;align-items:center;justify-content:space-between;gap:12px}.inline-actions{display:flex;gap:10px;flex-wrap:wrap}.disabled-block{opacity:.6}.pin-modal-backdrop{position:fixed;inset:0;background:rgba(5,11,20,.78);display:none;align-items:center;justify-content:center;padding:18px;z-index:9999}.pin-modal{width:min(100%,420px);background:#0d172a;border-radius:22px;padding:22px;border:1px solid var(--line);box-shadow:0 20px 60px rgba(0,0,0,.45)}.pin-status{min-height:18px;color:#fda4af;font-size:13px;margin-top:10px}
.footer-note{font-size:13px;color:var(--muted);margin-top:12px;line-height:1.5}
@media (max-width:1100px){.main-layout,.summary-hero{grid-template-columns:1fr}.days,.weekdays{grid-template-columns:repeat(7,1fr)}.hero-card .big{font-size:48px}}
@media (max-width:860px){.days,.weekdays{grid-template-columns:repeat(4,1fr)}.check-grid{grid-template-columns:1fr 1fr}.row{grid-template-columns:1fr}}
@media (max-width:640px){.wrap{padding:14px}.brand h1{font-size:24px}.summary-hero{grid-template-columns:1fr 1fr}.hero-card.primary{grid-column:1/-1}.hero-card .big{font-size:42px}.days,.weekdays{grid-template-columns:repeat(2,1fr)}.check-grid,.summary-hero{grid-template-columns:1fr}.weekday{text-align:left}.day.expanded{grid-column:1/-1}}

/* compact redesign */
.compact-topbar{align-items:flex-start;margin-bottom:14px}.compact-topbar .brand p{display:none}
.top-account-strip{display:flex;gap:10px;flex-wrap:wrap;align-items:center;justify-content:flex-end}
.mini-account-box{min-width:160px;padding:10px 14px;border-radius:18px;background:rgba(255,255,255,.05);border:1px solid rgba(148,163,184,.12);display:flex;flex-direction:column;gap:4px}
.mini-label,.section-kicker{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
.compact-logout{height:44px}.compact-pin-actions button{padding:10px 12px}
.quick-menu{display:flex;gap:10px;overflow:auto;padding:10px 12px;margin-bottom:14px}.menu-tab{white-space:nowrap;background:#0a1528;border:1px solid var(--line)}.menu-tab.active{background:linear-gradient(135deg,#1d4ed8,#2563eb)}
.compact-layout{grid-template-columns:minmax(0,1.45fr) minmax(320px,.85fr);align-items:start}.left-column,.right-column{display:grid;gap:16px}
.calendar-panel-top{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;margin-bottom:14px}.compact-toolbar{gap:8px;align-items:center;flex-wrap:wrap}.month-nav-group{display:flex;align-items:center;gap:8px;flex-wrap:wrap;background:#0a1528;border:1px solid var(--line);padding:8px 10px;border-radius:16px}.month-nav-group select{min-width:132px}.nav-month{padding:12px 14px;min-width:46px}.calendar-legend-title{display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:12px}.compact-legend{margin:0}.estimate-card{padding:0;overflow:hidden}.estimate-head{width:100%;padding:18px;background:transparent;border:none;display:flex;justify-content:space-between;align-items:center;text-align:left}.estimate-head h2{font-size:22px}.estimate-body{display:none;padding:0 0 6px}.estimate-body.open{display:block}
.show-weekdays{display:grid;grid-template-columns:repeat(7,1fr);gap:10px;margin-bottom:10px}.show-weekdays .weekday{display:flex;justify-content:center;align-items:center;padding:10px 0;border-radius:14px;background:#0a1528;border:1px solid var(--line);color:var(--muted);font-size:12px}
.calendar-grid{grid-template-columns:repeat(7,minmax(0,1fr));gap:10px}.day{min-height:104px;border:1px solid rgba(96,165,250,.16);border-radius:20px;padding:12px;background:linear-gradient(180deg,rgba(18,30,54,.96),rgba(11,19,38,.98));position:relative;cursor:pointer;transition:.18s transform,.18s border-color,.18s box-shadow,.18s background;box-shadow:0 10px 22px rgba(2,6,23,.18);overflow:hidden}.day::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at top right,rgba(56,189,248,.16),transparent 38%),radial-gradient(circle at bottom left,rgba(34,197,94,.12),transparent 34%);pointer-events:none}.day:hover{transform:translateY(-2px);border-color:#60a5fa;box-shadow:0 16px 32px rgba(2,6,23,.24),0 0 0 1px rgba(96,165,250,.08)}.day.empty{min-height:80px;background:transparent;border:1px dashed rgba(148,163,184,.08);cursor:default;box-shadow:none}.day.empty:hover{transform:none;border-color:rgba(148,163,184,.08);box-shadow:none}
.day-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;position:relative;z-index:1}.day .num{font-size:22px;font-weight:900;color:#f8fafc;text-shadow:0 1px 0 rgba(255,255,255,.06)}.day .meta{font-size:11px;color:#bdd0ea;margin-top:2px}.day-code{padding:6px 10px;border-radius:999px;font-size:12px;font-weight:900;background:#16233a;color:#dbeafe;border:1px solid rgba(148,163,184,.16);box-shadow:inset 0 1px 0 rgba(255,255,255,.12),0 8px 18px rgba(15,23,42,.16)}.code-M,.tiny-shift-btn.code-M{background:linear-gradient(135deg,rgba(16,185,129,.26),rgba(52,211,153,.22))!important;color:#dcfce7!important;border-color:rgba(52,211,153,.28)!important}.code-A,.tiny-shift-btn.code-A{background:linear-gradient(135deg,rgba(245,158,11,.28),rgba(251,191,36,.22))!important;color:#fef3c7!important;border-color:rgba(251,191,36,.26)!important}.code-N,.tiny-shift-btn.code-N{background:linear-gradient(135deg,rgba(37,99,235,.26),rgba(96,165,250,.22))!important;color:#dbeafe!important;border-color:rgba(96,165,250,.26)!important}.code-OFF,.tiny-shift-btn.code-OFF{background:linear-gradient(135deg,rgba(71,85,105,.34),rgba(100,116,139,.24))!important;color:#e2e8f0!important;border-color:rgba(148,163,184,.2)!important}.code-CO,.tiny-shift-btn.code-CO{background:linear-gradient(135deg,rgba(124,58,237,.28),rgba(167,139,250,.22))!important;color:#f5f3ff!important;border-color:rgba(196,181,253,.22)!important}.code-CM,.tiny-shift-btn.code-CM{background:linear-gradient(135deg,rgba(225,29,72,.28),rgba(251,113,133,.22))!important;color:#fff1f2!important;border-color:rgba(251,113,133,.24)!important}
.day-sub{margin-top:12px;font-size:13px;color:#e0f2fe;font-weight:600}.day-note-line{margin-top:12px;display:flex;flex-wrap:wrap;gap:6px}.mini-badge{padding:5px 8px;border-radius:999px;font-size:11px;border:1px solid rgba(148,163,184,.16);background:linear-gradient(135deg,rgba(30,41,59,.92),rgba(15,23,42,.96));color:#cbd5e1;box-shadow:inset 0 1px 0 rgba(255,255,255,.05)}.mini-badge.holiday{background:linear-gradient(135deg,rgba(244,63,94,.22),rgba(251,113,133,.14));border-color:rgba(251,113,133,.38);color:#ffe4e6}.mini-badge.weekend{background:linear-gradient(135deg,rgba(251,146,60,.22),rgba(251,191,36,.14));border-color:rgba(251,146,60,.38);color:#ffedd5}.mini-badge.ot{background:linear-gradient(135deg,rgba(14,165,233,.22),rgba(56,189,248,.14));border-color:rgba(56,189,248,.38);color:#e0f2fe}.mini-badge.note{background:linear-gradient(135deg,rgba(250,204,21,.2),rgba(251,191,36,.14));border-color:rgba(250,204,21,.34);color:#fef3c7}.note-preview{margin-top:6px;font-size:12px;color:#dbeafe;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.day.selected{outline:2px solid rgba(56,189,248,.58);box-shadow:0 0 0 3px rgba(59,130,246,.12),0 18px 36px rgba(2,6,23,.26)}.holiday-dot{position:absolute;top:10px;left:10px;width:8px;height:8px;border-radius:50%;background:var(--holiday);box-shadow:0 0 0 4px rgba(251,113,133,.14),0 0 12px rgba(251,113,133,.28)}
.compact-summary{margin:0}.compact-summary .hero-card .big{font-size:48px}.compact-summary .mini-stat .value{font-size:28px}
.collapsible-card{padding:0;overflow:hidden}.collapse-head{width:100%;padding:18px;background:transparent;border:none;display:flex;justify-content:space-between;align-items:center;text-align:left}.collapse-head h2{font-size:22px}.collapse-arrow{font-size:20px;color:var(--muted);transition:transform .2s ease}.collapse-head.active .collapse-arrow{transform:rotate(180deg)}.collapse-body{display:none;padding:0 18px 18px}.collapse-body.open{display:block}
.compact-fields-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.compact-actions-row{display:flex;gap:10px;flex-wrap:wrap}.holiday-year-list{display:grid;gap:8px}.holiday-item{display:flex;justify-content:space-between;gap:10px;padding:10px 12px;border-radius:16px;background:#0a1528;border:1px solid var(--line)}
.day-modal{max-width:760px;width:min(96vw,760px)}.day-modal-grid{display:grid;gap:12px}.shift-quick-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}.shift-secondary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}.tiny-shift-btn{padding:14px 10px;border-radius:16px;background:#0a1528;border:1px solid var(--line);font-weight:700}.tiny-shift-btn.active{outline:2px solid rgba(59,130,246,.55)}.modal-meta-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:6px}.tiny-checks{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}.tiny-check{padding:10px 12px;border-radius:14px;border:1px solid var(--line);background:#0a1528;display:flex;align-items:center;gap:8px;cursor:pointer}.tiny-check input{width:auto}.day-note-box textarea{width:100%;min-height:90px;padding:12px 14px;border-radius:16px;border:1px solid var(--line);background:#0a1528;color:var(--text);font:inherit;resize:vertical}.day-note-box textarea:focus{outline:none;border-color:#3b82f6;box-shadow:0 0 0 4px rgba(59,130,246,.12)}.muted-note{color:var(--muted);font-size:13px}.hours-quick-grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:8px;margin-top:8px}.hour-quick-btn{padding:10px 6px;border-radius:14px;border:1px solid var(--line);background:#0a1528;color:var(--text);font-weight:800;cursor:pointer}.hour-quick-btn.active{border-color:#60a5fa;box-shadow:0 0 0 2px rgba(96,165,250,.18);background:rgba(37,99,235,.22)}
@media (max-width: 1100px){.compact-layout{grid-template-columns:1fr}.right-column{grid-template-columns:1fr}.top-account-strip{justify-content:flex-start}}
@media (max-width: 760px){.compact-fields-grid,.shift-quick-grid,.tiny-checks{grid-template-columns:repeat(2,minmax(0,1fr))}.calendar-grid,.show-weekdays{gap:8px}.day{min-height:94px;padding:10px}.compact-toolbar{width:100%}.compact-toolbar select{flex:1;min-width:120px}.top-account-strip .mini-account-box{min-width:unset;flex:1 1 180px}}


.top-account-strip{align-items:center}
.mini-account-box{min-width:170px;background:linear-gradient(180deg,rgba(15,26,45,.95),rgba(8,17,31,.92));border:1px solid rgba(148,163,184,.16);box-shadow:0 10px 24px rgba(0,0,0,.18)}
.quick-menu{position:sticky;top:8px;z-index:5;background:linear-gradient(180deg,rgba(10,21,40,.94),rgba(8,16,30,.94));display:flex;gap:10px;flex-wrap:wrap}
.menu-tab{background:rgba(255,255,255,.03);border:1px solid rgba(148,163,184,.14);color:var(--text);padding:12px 14px;border-radius:14px}
.menu-tab.active{background:linear-gradient(135deg,#163a77,#1d4ed8);box-shadow:0 10px 24px rgba(29,78,216,.22)}
.days{gap:12px}
.day{background:linear-gradient(180deg,rgba(10,20,36,.94),rgba(8,16,30,.94));border:1px solid rgba(148,163,184,.14);box-shadow:0 8px 18px rgba(0,0,0,.16)}
.day:hover{transform:translateY(-2px);box-shadow:0 14px 24px rgba(0,0,0,.22)}
.day.selected{border-color:#60a5fa;box-shadow:0 0 0 3px rgba(96,165,250,.12),0 16px 28px rgba(0,0,0,.25)}
.day.weekend{background:linear-gradient(180deg,rgba(35,24,12,.92),rgba(22,16,9,.92))}
.day.holiday{background:linear-gradient(180deg,rgba(55,16,28,.92),rgba(28,10,18,.92));border-color:rgba(251,113,133,.45)}
.day-num{display:inline-flex;align-items:center;justify-content:center;min-width:34px;height:34px;border-radius:12px;background:rgba(255,255,255,.04);font-weight:800}
.holiday .day-num{background:rgba(251,113,133,.18);color:#ffd0dc}
.weekend .day-num{background:rgba(251,146,60,.14)}
.note-preview{line-height:1.35;max-height:2.8em}
.estimate-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
.stats-strip{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:10px;margin-top:14px}
.stat-chip{padding:14px 12px;border-radius:18px;border:1px solid rgba(148,163,184,.12);background:rgba(255,255,255,.03);display:flex;flex-direction:column;gap:8px}
.stat-chip .k{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
.stat-chip strong{font-size:22px}
.quick-report-note{margin-top:10px;color:var(--muted);font-size:13px}
@media (max-width: 980px){
  .stats-strip{grid-template-columns:repeat(2,minmax(0,1fr))}
  .quick-menu{position:static}
}



/* UX FIX v4 - mobile friendly editor + free monthly usage flow */
.pin-modal.day-modal{width:min(100%,460px);max-height:92vh;overflow:auto;padding:16px;border-radius:24px;}
.day-modal-grid{display:grid;gap:12px;}
.modal-day-header{display:grid;grid-template-columns:auto 1fr;gap:12px;align-items:center;}
.modal-day-number{width:54px;height:54px;border-radius:18px;display:grid;place-items:center;font-size:24px;font-weight:900;box-shadow:0 10px 24px rgba(0,0,0,.22);}
.modal-meta-row{display:flex;gap:8px;flex-wrap:wrap;margin:2px 0 4px;}
.shift-quick-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;}
.shift-secondary-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;}
.tiny-shift-btn{min-height:46px;border-radius:14px;font-weight:800;font-size:12px;padding:10px 8px;}
.tiny-shift-btn.active{outline:2px solid rgba(255,255,255,.5);transform:translateY(-1px);}
.hours-quick-grid{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:8px;margin-top:10px;}
.hour-quick-btn{padding:9px 4px;border-radius:12px;font-size:12px;font-weight:800;background:#0a1528;border:1px solid rgba(148,163,184,.18);}
.hour-quick-btn.active{background:#1d4ed8;color:#fff;border-color:#60a5fa;}
.tiny-checks{display:grid;grid-template-columns:1fr;gap:8px;}
.tiny-check{display:flex;align-items:center;gap:8px;padding:10px 12px;border-radius:14px;background:rgba(255,255,255,.04);border:1px solid rgba(148,163,184,.14);font-size:12px;}
.day-modal .muted-note{font-size:11px;line-height:1.35;color:#94a3b8;}
.day-modal textarea{min-height:72px;}
.day{cursor:pointer;touch-action:manipulation;}
.day:active,.tiny-shift-btn:active,.hour-quick-btn:active{transform:scale(.98);}
.free-banner strong::after{content:"";}
@media(max-width:520px){
  body{padding-bottom:78px;}
  .pin-modal-backdrop{padding:10px;align-items:flex-end;}
  .pin-modal.day-modal{border-radius:24px 24px 0 0;max-height:88vh;width:100%;}
  .shift-quick-grid,.shift-secondary-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
  .hours-quick-grid{grid-template-columns:repeat(5,minmax(0,1fr));}
  .calendar-panel-top,.calendar-legend-title{gap:8px;}
  .day{min-height:92px;padding:10px;}
  .day-sub,.mini-badge{font-size:10px;}
}

</style>
</head>
<body>
  <div id="langSwitcher" class="lang-switcher" aria-label="Language selector">
    <button type="button" class="lang-btn" data-lang="ro" title="Română"><span>🇷🇴</span></button>
    <button type="button" class="lang-btn" data-lang="en" title="English"><span>🇬🇧</span></button>
  </div>
  <div id="authScreen" class="wrap screen-shell">
    <div class="card auth-wrap auth-card">
      <div class="brand-chip">🔒 Autentificare securizată</div>
      <h2>Calculator Salariu</h2>
      <p class="desc">Intră în cont sau creează unul nou ca să folosești aplicația. Datele tale sunt salvate în cloud pe contul tău.</p>

      <div class="tabs" style="margin-bottom:12px;">
        <button id="tabRegisterMain" class="ghost" onclick="setMainAuthView('register')">Înregistrare</button>
        <button id="tabLoginMain" class="secondary" onclick="setMainAuthView('login')">Login</button>
      </div>

      <div id="registerMainPanel">
        <div class="field">
          <label>Email</label>
          <input id="mainRegEmail" type="email" placeholder="nume@email.com" />
        </div>
        <div class="field">
          <label>Parolă</label>
          <input id="mainRegPass" type="password" placeholder="minimum 6 caractere" />
        </div>
        <button id="mainRegisterBtn">Creează cont</button>
      </div>

      <div id="loginMainPanel" class="hidden">
        <div class="field">
          <label>Email</label>
          <input id="mainLoginEmail" type="email" placeholder="nume@email.com" />
        </div>
        <div class="field">
          <label>Parolă</label>
          <input id="mainLoginPass" type="password" placeholder="parola" />
        </div>
        <button id="mainLoginBtn">Intră în cont</button>
        <div id="deviceTransferWrap" class="hidden" style="margin-top:12px;display:none;gap:8px;flex-direction:column;">
          <div class="auth-note" id="deviceTransferMsg">Ai schimbat telefonul? Poți muta accesul pe acest dispozitiv după ce confirmi parola.</div>
          <button id="transferDeviceBtn" class="secondary" type="button">Mută contul pe acest dispozitiv</button>
        </div>
      </div>

      <div style="margin-top:12px;">
        <button class="ghost" onclick="resetMainPassword()">Forgot password</button>
      </div>

      <div class="auth-note">Plata pentru Premium este procesată securizat prin Google Play. Abonamentul tău poate fi restaurat pe același cont.</div>
      <p class="footer-note" id="mainAuthMsg"></p>
    </div>
  </div>

  <div id="premiumScreen" class="wrap screen-shell" style="display:none;">
    <div class="card auth-wrap premium-card">
      <div class="brand-chip">⭐ Premium</div>
      <div id="premiumStateChip" class="status-chip" data-state="checking">Se verifică Google Play Billing...</div>
      <h2>Activează Premium</h2>
      <p class="desc">Contul tău este pe plan free. Pentru acces complet la calculator și sincronizare avansată, ai nevoie de Premium.</p>
      <div class="premium-benefits">
        <div class="premium-benefit">✔ acces complet la calculator</div>
        <div class="premium-benefit">✔ salvare date în cloud</div>
        <div class="premium-benefit">✔ actualizări și funcții noi</div>
      </div>
      <div class="list">
        <div class="item"><span class="muted">Plan curent</span><strong id="premiumPlanLabel">free</strong></div>
        <div class="item"><span class="muted">Cont</span><strong id="premiumUserEmail">-</strong></div>
      </div>
      <div style="margin-top:12px;display:grid;gap:10px;">
        <button id="goToPlayBtn">Se verifică...</button>
        <button id="restorePremiumBtn" class="ghost">Restore Premium</button>
        <button id="premiumBackBtn" class="ghost">Înapoi în aplicație</button>
        <button id="premiumLogoutBtn" class="secondary">Logout</button>
      </div>
      <div class="hint-box">Abonamentul premium se verifică automat din Google Play pe acest cont. Dacă schimbi telefonul sau reinstalezi aplicația, folosește butonul Restore Premium.</div>
      <p id="premiumMsg" class="footer-note"></p>
      <div class="hint-box">Plata abonamentului este procesată securizat prin Google Play. Poți restaura premium oricând pe același cont Google Play.</div>
    </div>
  </div>

  <div id="appScreen" class="wrap" style="display:none;">
    <div class="topbar compact-topbar">
      <div class="brand">
        <div class="logo" aria-label="Calculator Salariu"></div>
        <div>
          <h1>Calculator Salariu</h1>
        </div>
      </div>
      <div class="top-account-strip">
        <div class="mini-account-box">
          <span class="mini-label">Cont</span>
          <strong id="currentUserEmail">-</strong>
        </div>
        <div class="mini-account-box">
          <span class="mini-label">Plan</span>
          <strong id="currentPlanLabel">free</strong>
        </div>
        <div id="premiumQuickActions" class="inline-actions compact-pin-actions" style="display:none;">
          <button id="restorePremiumTopBtn" class="ghost">Restore Premium</button>
        </div>
        <div id="usageBadge" style="display:none;font-size:12px;padding:6px 10px;border-radius:999px;background:rgba(255,255,255,.05);border:1px solid rgba(148,163,184,.14);color:#94a3b8;font-weight:600;white-space:nowrap;"></div>
        <button id="logoutBtn" class="secondary compact-logout">Logout</button>
      </div>
    </div>

    <div class="quick-menu card">
      <button class="menu-tab active" data-target="calendarSection">Calendar</button>
      <button class="menu-tab" data-target="estimateSection">Estimare</button>
      <button class="menu-tab" data-target="rulesSection">Reguli</button>
      <button class="menu-tab" data-target="detailSection">Detalii</button>
      <button class="menu-tab" data-target="holidaysSection">Sărbători</button>
      <button class="menu-tab" data-target="logicSection">Logică</button>
      <button class="menu-tab" id="historyTabBtn" data-target="historySection">Istoric</button>
    </div>

    <div id="freeModeBanner" class="free-banner">
      <div>
        <strong>Cont Free: 15 calcule/lună</strong>
        <span>Poți edita și calcula. La fiecare 3 calcule apare o reclamă. Premium elimină limita și reclamele.</span>
      </div>
      <div class="inline-actions">
        <button id="openPremiumFromBanner">Vezi Premium</button>
      </div>
    </div>

    <div class="grid compact-layout">
      <div class="left-column">
        <div class="card app-panel" id="calendarSection">
          <div class="calendar-panel-top">
            <div>
              <div class="section-kicker">Programul tău lunar</div>
              <h2>Calendar rapid</h2>
            </div>
            <div class="toolbar compact-toolbar">
              <div class="month-nav-group">
                <button id="prevMonthBtn" class="secondary nav-month" aria-label="Luna anterioară">‹</button>
                <select id="monthSelect"></select>
                <button id="nextMonthBtn" class="secondary nav-month" aria-label="Luna următoare">›</button>
                <select id="yearSelect"></select>
              </div>
              <button id="todayBtn" class="ghost">Azi</button>
              <button id="resetMonth" class="secondary">Reset</button>
              <button id="tutorialBtn" class="ghost">Tutorial</button>
            </div>
          </div>

          <div class="calendar-legend-title">
            <strong>Calendar</strong>
            <div class="legend compact-legend">
              <div class="pill"><span class="sw" style="background:var(--morning)"></span>Morning</div>
              <div class="pill"><span class="sw" style="background:var(--after)"></span>After</div>
              <div class="pill"><span class="sw" style="background:var(--night)"></span>Night</div>
              <div class="pill"><span class="sw" style="background:#31425f"></span>Liber</div>
              <div class="pill"><span class="sw" style="background:var(--holiday)"></span>Sărbătoare</div>
            </div>
          </div>

          <div class="weekdays show-weekdays" id="weekdays"></div>
          <div id="days" class="days calendar-grid"></div>
        </div>

        <div class="card estimate-card" id="estimateSection">
          <button class="estimate-head collapse-head" data-collapse="estimateBody">
            <div>
              <span class="section-kicker">Rezumat rapid</span>
              <h2>Estimare lunară</h2>
            </div>
            <span class="collapse-arrow">▾</span>
          </button>
          <div id="estimateBody" class="estimate-body open">
            <!-- Hero net salary -->
            <div class="est-hero-row">
              <div class="est-hero-net">
                <div class="est-hero-label">Salariu net</div>
                <div id="sumNet" class="est-hero-value">—</div>
                <div class="est-hero-sub" id="estMonthLabel"></div>
              </div>
              <div class="est-side-grid">
                <div class="est-side-card">
                  <div class="est-side-label">Tichete masă</div>
                  <div id="sumMeals" class="est-side-value">—</div>
                </div>
                <div class="est-side-card highlight">
                  <div class="est-side-label">Total încasat</div>
                  <div id="sumTotal" class="est-side-value">—</div>
                </div>
                <div class="est-side-card">
                  <div class="est-side-label">Sporuri + OT</div>
                  <div id="sumExtras" class="est-side-value est-extras">—</div>
                </div>
                <div class="est-side-card">
                  <div class="est-side-label">Brut estimat</div>
                  <div id="sumGrossEst" class="est-side-value est-gross">—</div>
                </div>
              </div>
            </div>

            <!-- shift type chips -->
            <div class="shift-chips-row">
              <div class="shift-chip chip-m"><span class="shift-chip-icon">M</span><div><div class="shift-chip-count" id="statMorning">—</div><div class="shift-chip-name">Morning</div></div></div>
              <div class="shift-chip chip-a"><span class="shift-chip-icon">A</span><div><div class="shift-chip-count" id="statAfter">—</div><div class="shift-chip-name">After</div></div></div>
              <div class="shift-chip chip-n"><span class="shift-chip-icon">N</span><div><div class="shift-chip-count" id="statNight">—</div><div class="shift-chip-name">Night</div></div></div>
              <div class="shift-chip chip-ot"><span class="shift-chip-icon">OT</span><div><div class="shift-chip-count" id="statOvertime">—</div><div class="shift-chip-name">Overtime</div></div></div>
